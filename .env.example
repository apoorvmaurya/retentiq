# Supabase Connection Keys
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Connection (Direct & Session pooler)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# AI Services
GROQ_API_KEY=your-groq-api-key

# Stripe (Billing webhook)
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Intercom (CRM integration)
INTERCOM_CLIENT_SECRET=your-intercom-client-secret

# Mixpanel (Analytics)
MIXPANEL_SERVICE_ACCOUNT_USERNAME=your-mixpanel-sa-username
MIXPANEL_SERVICE_ACCOUNT_SECRET=your-mixpanel-sa-secret

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Email SMTP Setup
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@retentiq.io

# Client Public Env Variables (For Web App)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
