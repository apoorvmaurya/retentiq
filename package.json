{
  "name": "retentiq-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @retentiq/web dev",
    "dev:api": "pnpm --filter @retentiq/api dev",
    "dev:ai": "cd apps/ai-service && uvicorn main:app --reload",
    "dev": "pnpm run --parallel dev:web dev:api",
    "build": "pnpm --filter @retentiq/shared build && pnpm --filter @retentiq/db build && pnpm --filter @retentiq/api build && pnpm --filter @retentiq/web build",
    "seed": "pnpm --filter @retentiq/db seed",
    "lint": "eslint \"**/*.{ts,tsx}\" --quiet",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml,sql}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,sql}": [
      "prettier --write"
    ]
  }
}
