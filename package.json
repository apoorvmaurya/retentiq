{
  "name": "retentiq-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev:web": "pnpm --filter @retentiq/web dev",
    "dev:api": "pnpm --filter @retentiq/api dev",
    "dev:ai": "uvicorn main:app --app-dir apps/ai-service --reload",
    "dev": "pnpm --filter @retentiq/web --filter @retentiq/api dev",
    "start:web": "pnpm --filter @retentiq/web start",
    "start:api": "pnpm --filter @retentiq/api start",
    "start": "pnpm --filter @retentiq/web --filter @retentiq/api start",
    "build": "pnpm --filter @retentiq/shared build && pnpm --filter @retentiq/db build && pnpm --filter @retentiq/api build && pnpm --filter @retentiq/web build",
    "vercel-build": "pnpm --filter @retentiq/shared build && pnpm --filter @retentiq/db build && pnpm --filter @retentiq/web build",
    "seed": "pnpm --filter @retentiq/db seed",
    "db:generate": "pnpm --filter @retentiq/db db:generate",
    "db:push": "pnpm --filter @retentiq/db db:push",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "lint": "eslint \"**/*.{ts,tsx}\" --quiet",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "test:ai": "apps\\ai-service\\.venv\\Scripts\\python apps/ai-service/test_sklearn.py",
    "prepare": "node -e \"try { if (!process.env.CI && process.env.NODE_ENV !== 'production' && require('fs').existsSync('.git')) { require('child_process').execSync('husky', { stdio: 'inherit' }) } } catch (e) {}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.65.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.6",
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "postcss": "^8.5.15",
      "form-data": "^4.0.6"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
