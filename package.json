{
  "name": "retentiq-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @retentiq/web dev",
    "dev:api": "pnpm --filter @retentiq/api dev",
    "dev:ai": "cd apps/ai-service && uvicorn main:app --reload",
    "dev": "pnpm --filter @retentiq/web --filter @retentiq/api dev",
    "start:web": "pnpm --filter @retentiq/web start",
    "start:api": "pnpm --filter @retentiq/api start",
    "start": "pnpm --filter @retentiq/web --filter @retentiq/api start",
    "build": "pnpm --filter @retentiq/shared build && pnpm --filter @retentiq/db build && pnpm --filter @retentiq/api build && pnpm --filter @retentiq/web build",
    "vercel-build": "pnpm --filter @retentiq/shared build && pnpm --filter @retentiq/db build && pnpm --filter @retentiq/api build",
    "seed": "pnpm --filter @retentiq/db seed",
    "lint": "eslint \"**/*.{ts,tsx}\" --quiet",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "prepare": "node -e \"try { if (!process.env.CI && process.env.NODE_ENV !== 'production') { require('child_process').execSync('husky', { stdio: 'inherit' }) } } catch (e) {}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.24.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "allowedBuildScripts": [
      "esbuild"
    ]
  }
}
