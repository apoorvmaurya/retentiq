# =========================================================================
# RetentIQ Local Environment Template (.env.local.example)
# =========================================================================

# -------------------------------------------------------------------------
# 1. Network & System Configurations
# -------------------------------------------------------------------------
# Local port configuration for services
PORT=3000
API_PORT=4000
NODE_ENV=development

# Canonical frontend, API, and AI service URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
AI_SERVICE_URL=http://localhost:8000

# -------------------------------------------------------------------------
# 2. Database Connection Strings (Supabase Postgres)
# -------------------------------------------------------------------------
# Connection Pooler (Transaction mode, port 6543) - Recommended for application connections
DATABASE_URL=postgresql://postgres:postgres@localhost:6543/postgres?sslmode=disable

# Direct Connection (Port 5432) - Required for migrations and seed execution
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

# -------------------------------------------------------------------------
# 3. Supabase Auth & Storage API Keys
# -------------------------------------------------------------------------
# Target project URL and API keys
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Client Public Env Variables (Mirrors above, prefixed for Next.js runtime bundling)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -------------------------------------------------------------------------
# 4. Third-Party Integrations Hub Keys
# -------------------------------------------------------------------------
# GROQ API Key for Llama model inference and risk explainability
GROQ_API_KEY=your-groq-api-key

# Stripe API Key & Webhook signing secret (Stripe SDK client & webhook verification)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Intercom OAuth CRM client secret (used for support ticket webhook verification)
INTERCOM_CLIENT_SECRET=your-intercom-client-secret

# Mixpanel Service Account credentials (used for user usage log downloads)
MIXPANEL_SERVICE_ACCOUNT_USERNAME=your-mixpanel-sa-username
MIXPANEL_SERVICE_ACCOUNT_SECRET=your-mixpanel-sa-secret

# -------------------------------------------------------------------------
# 5. System Notifications & Alerting (Slack Webhook)
# -------------------------------------------------------------------------
# Slack Webhook URL (used for CSM team channel alerting)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# -------------------------------------------------------------------------
# 6. Transactional Mail Server Settings (SMTP)
# -------------------------------------------------------------------------
# Node-mailer transport settings for CSM alerts and digest notifications
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@retentiq.io

# -------------------------------------------------------------------------
# 7. Internal System Security Keys
# -------------------------------------------------------------------------
# Secret token to authenticate and trigger cron/poller tasks in serverless environments
CRON_SECRET=your-cron-secret-key-32-chars-or-more

# Symmetric encryption key (32-character string) to encrypt tenant API secrets at rest using AES-256-GCM
ENCRYPTION_KEY=your-secure-32-character-encryption-key-here
