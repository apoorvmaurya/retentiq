{
  "name": "@retentiq/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "postbuild": "node copy-static.js",
    "start": "node -e \"const fs = require('fs'); const { spawnSync } = require('child_process'); const args = fs.existsSync('.env.local') ? ['--env-file=.env.local'] : []; process.exit(spawnSync('node', [...args, '.next/standalone/apps/web/server.js'], { stdio: 'inherit' }).status ?? 0);\"",
    "lint": "next lint"
  },
  "dependencies": {
    "@retentiq/shared": "workspace:*",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "framer-motion": "^12.0.6",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.20.0",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.1",
    "typescript": "^6"
  }
}
